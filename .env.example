# Used server-side by next.config.ts (rewrites) and the auth route handlers
ATLAS_BACKEND_URL=http://127.0.0.1:8000

# If set, the client calls the backend directly instead of through the
# Next.js rewrite proxy. Leave unset to use /api/backend/* (recommended
# for local dev so cookies/CORS stay same-origin).
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Firebase Configuration (for Google Sign-In)
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDWQJ9v2KazHhR5rIHRZ6Zj5OmIX4mVjno
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=atlas-ai-assistant-1ae91.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=atlas-ai-assistant-1ae91
